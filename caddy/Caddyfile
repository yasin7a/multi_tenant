# Caddy — replaces nginx
# Main domain: multi.takitahmid.com
# Subdomains + custom domains: on-demand SSL (via /internal/caddy-ask)

{
	email ACME_EMAIL_PLACEHOLDER

	on_demand_tls {
		ask http://127.0.0.1:3000/internal/caddy-ask
	}
}

# Main domain only — do NOT use *.wildcard here (needs DNS challenge, fails to start)
multi.takitahmid.com {
	request_body {
		max_size 6MB
	}

	reverse_proxy 127.0.0.1:3000 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}

# user.multi.takitahmid.com + user custom domains
https:// {
	tls {
		on_demand
	}

	request_body {
		max_size 6MB
	}

	reverse_proxy 127.0.0.1:3000 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}
