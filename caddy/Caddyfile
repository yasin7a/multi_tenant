# Caddy — replaces nginx entirely
# Platform: multi.takitahmid.com + *.multi.takitahmid.com (auto SSL)
# Custom domains: on-demand SSL (only if domain saved in app DB)

{
	email {$ACME_EMAIL:admin@takitahmid.com}

	on_demand_tls {
		ask http://127.0.0.1:3000/internal/caddy-ask
		interval 2m
		burst 5
	}
}

# Main app + user subdomains
multi.takitahmid.com, *.multi.takitahmid.com {
	request_body {
		max_size 6MB
	}

	reverse_proxy 127.0.0.1:3000 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}

# User custom domains (SSL issued automatically on first visit)
:443 {
	tls {
		on_demand
	}

	request_body {
		max_size 6MB
	}

	reverse_proxy 127.0.0.1:3000 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}
