{
	email takitahmid20@gmail.com

	on_demand_tls {
		ask http://127.0.0.1:3000/internal/caddy-ask
	}
}

(proxy) {
	request_body {
		max_size 6MB
	}

	reverse_proxy 127.0.0.1:3000
}

:80 {
	import proxy
}

__ROOT_DOMAIN__, *.__ROOT_DOMAIN__ {
	tls /etc/caddy/certs/fullchain.pem /etc/caddy/certs/privkey.pem

	import proxy
}

https:// {
	tls {
		on_demand
	}

	import proxy
}
