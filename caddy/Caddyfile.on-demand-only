# Fallback when wildcard cert is missing (slow ~5s first visit per hostname).
{
	email ACME_EMAIL_PLACEHOLDER

	on_demand_tls {
		ask http://127.0.0.1:3000/internal/caddy-ask
	}
}

https:// {
	tls {
		on_demand
	}

	request_body {
		max_size 6MB
	}

	reverse_proxy 127.0.0.1:3000 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
	}
}
