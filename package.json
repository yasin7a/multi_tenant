{
  "name": "multi-tenant-app",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --exec node server.js",
    "p:migrate": "npx prisma migrate dev",
    "p:gen": "npx prisma generate",
    "p:valid": "npx prisma format && npx prisma validate",
    "p:all": "npm run p:valid && npm run p:gen && npm run p:migrate",
    "seed": "node prisma/seed.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/formbody": "^8.0.2",
    "@fastify/static": "^9.1.3",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "bcryptjs": "^3.0.2",
    "dotenv": "^17.0.0",
    "ejs": "^6.0.1",
    "fastify": "^5.3.3",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.10",
    "prisma": "^7.0.0"
  }
}
