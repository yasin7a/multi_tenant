<div class="card">
  <h1>Welcome back</h1>
  <p class="meta">Sign in to manage your tenant.</p>
  <% if (error) { %><div class="error"><%= error %></div><% } %>
  <form method="post" action="/login">
    <label>
      Email
      <input type="email" name="email" value="<%= values.email || '' %>" placeholder="you@gmail.com" required>
    </label>
    <label>
      Password
      <input type="password" name="password" placeholder="••••••••" required>
    </label>
    <button type="submit" class="btn-block">Sign in</button>
  </form>
  <p class="footer-note">No account? <a href="/register">Create one</a></p>
</div>
