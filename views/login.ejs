<div class="card">
  <h1>Welcome back</h1>
  <p class="meta">Sign in to manage your tenant.</p>
  <% if (error) { %><div class="error"><%= error %></div><% } %>
  <% if (redirectUrl) { %>
    <p class="meta redirect-countdown">Redirecting in <strong id="login-countdown"><%= redirectSeconds %></strong>s…</p>
    <p class="meta"><a href="<%= redirectUrl %>">Go now</a></p>
  <% } %>
  <form method="post" action="/login">
    <label>
      Email
      <input type="email" name="email" value="<%= values.email || '' %>" placeholder="you@gmail.com" required>
    </label>
    <label>
      Password
      <input type="password" name="password" placeholder="••••••••" required>
    </label>
    <button type="submit" class="btn-block">Sign in</button>
  </form>
  <p class="footer-note">No account? <a href="/register">Create one</a></p>
</div>

<% if (redirectUrl) { %>
<script>
  (function () {
    const url = <%- JSON.stringify(redirectUrl) %>;
    let seconds = <%= redirectSeconds %>;
    const el = document.getElementById('login-countdown');
    const timer = setInterval(() => {
      seconds -= 1;
      if (el) el.textContent = String(seconds);
      if (seconds <= 0) {
        clearInterval(timer);
        window.location.href = url;
      }
    }, 1000);
  })();
</script>
<% } %>
