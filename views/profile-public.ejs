<div class="card">
  <div class="profile-header profile-header-public">
    <% if (user.imageUrl) { %>
      <img class="avatar avatar-lg avatar-img" src="<%= user.imageUrl %>" alt="<%= user.username %>">
    <% } else { %>
      <div class="avatar avatar-lg"><%= user.username.charAt(0).toUpperCase() %></div>
    <% } %>
    <div>
      <span class="badge">Public profile</span>
      <h1><%= user.username %></h1>
      <p class="meta"><a href="<%= profileUrl %>"><%= user.tenant.subdomain %>.<%= rootDomain %></a></p>
    </div>
  </div>

  <section class="metadata-section" aria-label="Profile metadata">
    <h2>Profile info</h2>
    <div class="info-grid">
      <div class="info-item">
        <label>Username</label>
        <p><%= user.username %></p>
      </div>
      <div class="info-item">
        <label>Email</label>
        <p><a href="mailto:<%= user.email %>"><%= user.email %></a></p>
      </div>
      <div class="info-item">
        <label>Profile URL</label>
        <p><a href="<%= profileUrl %>"><%= user.tenant.subdomain %>.<%= rootDomain %></a></p>
      </div>
      <div class="info-item">
        <label>Subdomain</label>
        <p><%= user.tenant.subdomain %></p>
      </div>
      <div class="info-item">
        <label>Member since</label>
        <p><time datetime="<%= new Date(user.createdAt).toISOString() %>"><%= memberSince %></time></p>
      </div>
      <div class="info-item">
        <label>Site created</label>
        <p><time datetime="<%= new Date(user.tenant.createdAt).toISOString() %>"><%= siteCreated %></time></p>
      </div>
    </div>
  </section>

  <div class="actions">
    <a class="btn" href="<%= loginUrl %>">Sign in</a>
  </div>
</div>
