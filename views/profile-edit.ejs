<div class="card">
  <div class="profile-header">
    <% if (user.imageUrl) { %>
      <img class="avatar avatar-img" src="<%= user.imageUrl %>" alt="<%= user.username %>">
    <% } else { %>
      <div class="avatar"><%= user.username.charAt(0).toUpperCase() %></div>
    <% } %>
    <div>
      <span class="badge">Your account</span>
      <h1><%= user.username %></h1>
    </div>
  </div>

  <% if (error) { %><div class="error"><%= error %></div><% } %>
  <% if (success) { %><div class="success"><%= success %></div><% } %>

  <form method="post" action="/edit" enctype="multipart/form-data">
    <label>
      Profile image
      <input type="file" name="image" accept="image/jpeg,image/png,image/gif,image/webp">
      <span class="meta">JPEG, PNG, GIF, or WebP. Max 5 MB.</span>
    </label>
    <label>
      Username
      <input type="text" name="username" value="<%= user.username %>" required>
    </label>
    <label>
      Email
      <input type="email" name="email" value="<%= user.email %>" required>
    </label>
    <label>
      Custom domain
      <input type="text" name="customDomain" id="custom-domain-input" value="<%= user.tenant.customDomain || '' %>" placeholder="mysite.com">
      <span class="meta">Optional. Point your domain to this server, then enter it here.</span>
    </label>

    <div id="domain-status-panel" class="domain-status-panel<%= user.tenant.customDomain ? '' : ' hidden' %>">
      <div class="domain-status-row">
        <span class="domain-status-name" id="domain-status-name"><%= user.tenant.customDomain || '' %></span>
        <span class="domain-status-badge <%= customDomainVerified ? 'is-valid' : 'is-pending' %>" id="domain-status-badge">
          <% if (customDomainVerified) { %>
            <span class="domain-check" aria-hidden="true">✓</span>
            <span>Valid Configuration</span>
          <% } else { %>
            <span class="domain-pending-dot" aria-hidden="true"></span>
            <span>Pending DNS</span>
          <% } %>
        </span>
      </div>
      <p class="meta domain-status-hint" id="domain-status-hint">
        <% if (customDomainVerified) { %>
          DNS is pointing to this server. HTTPS will be issued automatically on first visit.
        <% } else if (serverIp) { %>
          Add an A record pointing to <strong><%= serverIp %></strong>, then refresh this page.
        <% } else { %>
          Configure DNS at your domain provider, then refresh this page.
        <% } %>
      </p>
    </div>

    <p class="meta">Your site: <strong><span id="subdomain-preview"><%= user.tenant.subdomain %></span>.<%= rootDomain %></strong> (updates with username)</p>
    <button type="submit" class="btn-block">Save changes</button>
  </form>

  <% if (serverIp) { %>
    <div class="dns-help" id="dns-help">
      <label>DNS setup for custom domain</label>
      <p>Add an <strong>A record</strong> at your domain provider:</p>
      <div class="info-item">
        <label>Type</label>
        <p>A</p>
      </div>
      <div class="info-item">
        <label>Name / Host</label>
        <p id="dns-host-hint">@ (or your domain root)</p>
      </div>
      <div class="info-item">
        <label>Value</label>
        <p><%= serverIp %></p>
      </div>
      <p class="meta">After DNS propagates (5–30 min), a green checkmark appears above with <strong>Valid Configuration</strong>.</p>
    </div>
  <% } %>

  <script>
    const domainInput = document.getElementById('custom-domain-input')
    const statusPanel = document.getElementById('domain-status-panel')
    const statusName = document.getElementById('domain-status-name')
    const statusBadge = document.getElementById('domain-status-badge')
    const statusHint = document.getElementById('domain-status-hint')
    const dnsHostHint = document.getElementById('dns-host-hint')
    const serverIp = <%- JSON.stringify(serverIp || '') %>
    let verifyTimer

    function getDnsHostHint(domain) {
      if (!domain || !domain.includes('.')) return '@ (or your domain root)'
      const parts = domain.split('.')
      if (parts.length <= 2) return '@ (or your domain root)'
      return parts[0] + ' (subdomain)'
    }

    function renderDomainStatus(data) {
      if (!data.domain) {
        statusPanel.classList.add('hidden')
        return
      }

      statusPanel.classList.remove('hidden')
      statusName.textContent = data.domain

      if (data.verified) {
        statusBadge.className = 'domain-status-badge is-valid'
        statusBadge.innerHTML = '<span class="domain-check" aria-hidden="true">✓</span><span>Valid Configuration</span>'
        statusHint.innerHTML = 'DNS is pointing to this server. HTTPS will be issued automatically on first visit.'
      } else {
        statusBadge.className = 'domain-status-badge is-pending'
        statusBadge.innerHTML = '<span class="domain-pending-dot" aria-hidden="true"></span><span>Pending DNS</span>'
        statusHint.innerHTML = serverIp
          ? 'Add an A record pointing to <strong>' + serverIp + '</strong>. Checking again…'
          : 'Configure DNS at your domain provider. Checking again…'
      }
    }

    async function verifyDomain(domain) {
      const value = domain.trim().toLowerCase()
      if (!value) {
        renderDomainStatus({ domain: null })
        return
      }

      try {
        const res = await fetch('/api/custom-domain/verify?domain=' + encodeURIComponent(value), {
          headers: { accept: 'application/json' },
        })
        if (!res.ok) return
        renderDomainStatus(await res.json())
      } catch {}
    }

    function scheduleVerify() {
      clearTimeout(verifyTimer)
      const value = domainInput.value.trim().toLowerCase()
      if (dnsHostHint) dnsHostHint.textContent = getDnsHostHint(value)
      verifyTimer = setTimeout(() => verifyDomain(value), 400)
    }

    domainInput.addEventListener('input', scheduleVerify)
    scheduleVerify()
    setInterval(() => {
      if (domainInput.value.trim()) verifyDomain(domainInput.value)
    }, 15000)

    document.querySelector('input[name="username"]').addEventListener('input', (e) => {
      document.getElementById('subdomain-preview').textContent = e.target.value.toLowerCase()
    })
  </script>

  <div class="site-link">
    <label>Public page</label>
    <% if (user.tenant.customDomain) { %>
      <span class="site-link-domain">
        <% if (customDomainVerified) { %><span class="domain-check inline" title="Valid Configuration">✓</span><% } %>
        <a href="https://<%= user.tenant.customDomain %>"><%= user.tenant.customDomain %></a>
      </span>
      <span class="meta"> · </span>
    <% } %>
    <a href="/" id="public-page-link"><%= user.tenant.subdomain %>.<%= rootDomain %></a>
  </div>
</div>
